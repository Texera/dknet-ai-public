    {
      "title": "Avg duration last 24h",
      "type": "stat",
      "id": 4,
      "datasource": {"type": "grafana-postgresql-datasource", "uid": "texera-pg"},
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "targets": [{"refId": "A", "format": "table", "rawQuery": true,
        "rawSql": "SELECT COALESCE(AVG(EXTRACT(EPOCH FROM (last_update_time - starting_time))), 0) AS value FROM texera_db.workflow_executions WHERE last_update_time IS NOT NULL AND starting_time > NOW() - INTERVAL '24 hours' AND status IN (3,4,5)"}],
