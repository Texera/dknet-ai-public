      "targets": [{"refId": "A", "format": "table", "rawQuery": true,
        "rawSql": "SELECT COALESCE(percentile_cont(0.95) WITHIN GROUP (ORDER BY EXTRACT(EPOCH FROM (last_update_time - starting_time))), 0) AS value FROM texera_db.workflow_executions WHERE last_update_time IS NOT NULL AND starting_time > NOW() - INTERVAL '24 hours' AND status IN (3,4,5)"}],
